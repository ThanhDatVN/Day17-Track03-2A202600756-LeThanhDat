# ── Provider selection ──────────────────────────────────────────────────────
# Supported: openai | anthropic | gemini | ollama | openrouter | custom
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic ───────────────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# ── Google Gemini ────────────────────────────────────────────────────────────
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-flash
# GEMINI_API_KEY=AIza...

# ── Ollama (local, no key needed) ───────────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ── OpenRouter ──────────────────────────────────────────────────────────────
# LLM_PROVIDER=openrouter
# LLM_MODEL=openai/gpt-4o-mini
# OPENROUTER_API_KEY=sk-or-...

# ── Custom OpenAI-compatible endpoint ───────────────────────────────────────
# LLM_PROVIDER=custom
# LLM_MODEL=your-model-name
# CUSTOM_BASE_URL=https://your-endpoint.com/v1
# CUSTOM_API_KEY=your-key

# ── Judge model (dùng để đánh giá recall, mặc định dùng cùng provider) ─────
# JUDGE_LLM_PROVIDER=openai
# JUDGE_LLM_MODEL=gpt-4o-mini

# ── Compact memory settings ──────────────────────────────────────────────────
# COMPACT_THRESHOLD_TOKENS=800
# COMPACT_KEEP_MESSAGES=4
